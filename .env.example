# Pix Compliance AaaS v7.0 — Backend Environment
# Copy to .env and fill in values

NODE_ENV=development
PORT=3001

# JWT — MUST be at least 32 chars, use a cryptographically random value in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_chars_random_string_for_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_ME_different_min_32_chars_random_string
JWT_REFRESH_EXPIRES_IN=7d

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:8080

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

APP_NAME=Pix Compliance AaaS
APP_VERSION=7.0.0

# Cookie security
COOKIE_SECRET=CHANGE_ME_min_32_chars_random_string
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false

# ─────────────────────────────────────────────────────────────
# BACEN PIX API Integration (optional)
# ─────────────────────────────────────────────────────────────
# Leave blank to run in demo mode (synthetic PIX data, clearly labeled).
# Fill ALL of the following to activate the real BACEN PIX connector.
#
# The connector uses OAuth 2.0 (client_credentials) over mTLS, as required
# by BACEN. Certificates may be provided as raw PEM or base64-encoded PEM.

# PSP Pix API resource server base URL (e.g. https://pix.seubanco.com.br/api/v2)
BACEN_PIX_BASE_URL=
# OAuth 2.0 token endpoint (e.g. https://oauth.seubanco.com.br/token)
BACEN_PIX_TOKEN_URL=
BACEN_PIX_CLIENT_ID=
BACEN_PIX_CLIENT_SECRET=
# ISPB of your institution (8 digits)
BACEN_PIX_ISPB=
# OAuth scope (default: pix.read)
BACEN_PIX_SCOPE=pix.read
# mTLS client certificate + private key (PEM or base64-PEM)
BACEN_PIX_CERT=
BACEN_PIX_KEY=
# Optional: CA bundle (e.g. ICP-Brasil root) and key passphrase
BACEN_PIX_CA=
BACEN_PIX_KEY_PASSPHRASE=

# ─────────────────────────────────────────────────────────────
# Additional integrations (optional — demo mode until configured)
# ─────────────────────────────────────────────────────────────
# Each integration activates its real connector when BOTH its BASE_URL
# and API_KEY are set. Otherwise it serves clearly-labeled demo data.
# All use a generic REST contract, compatible with any vendor that
# exposes the relevant endpoints (Splunk/Elastic/Sentinel for SIEM,
# Cloudflare/AWS WAF for WAF, Thales/CloudHSM for HSM, etc.).

# ML Fraud Engine (fraud rate, anomalies, transaction scoring)
FRAUD_ENGINE_BASE_URL=
FRAUD_ENGINE_API_KEY=

# SIEM (9-layer security view, threat feed)
SIEM_BASE_URL=
SIEM_API_KEY=

# HSM / KMS (crypto layer health)
HSM_BASE_URL=
HSM_API_KEY=

# WAF / Edge (blocked threats, DDoS)
WAF_BASE_URL=
WAF_API_KEY=

# Transaction DB gateway (historical volume)
TXDB_BASE_URL=
TXDB_API_KEY=

# Business metrics (revenue, ROI, executive KPIs — from billing/CRM/DW)
BUSINESS_METRICS_BASE_URL=
BUSINESS_METRICS_API_KEY=
