# Pix Compliance AaaS v7.0 — Backend Environment
# Copy to .env and fill in values

NODE_ENV=development
PORT=3001

# JWT — MUST be at least 32 chars, use a cryptographically random value in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_chars_random_string_for_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_ME_different_min_32_chars_random_string
JWT_REFRESH_EXPIRES_IN=7d

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:8080

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

APP_NAME=Pix Compliance AaaS
APP_VERSION=7.0.0

# Cookie security
COOKIE_SECRET=CHANGE_ME_min_32_chars_random_string
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
